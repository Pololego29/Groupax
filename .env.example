# ============================================================================
# BASE DE DONNÉES
# ============================================================================
# PostgreSQL (Neon, Supabase, Railway, etc.)
# Laisser vide en local → SQLite automatique (data/offers.db)
DATABASE_URL=postgresql://user:password@host/dbname

# ============================================================================
# FRONTEND
# ============================================================================
# URL du frontend déployé (pour restreindre le CORS)
# Laisser vide en local → CORS ouvert pour tous les domaines
FRONTEND_URL=https://votre-app.vercel.app

# ============================================================================
# LOGGING
# ============================================================================
# Niveaux: DEBUG, INFO (default), WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# SCRAPING (Optionnel)
# ============================================================================
# Nombre de pages à scraper
MAX_PAGES=5

# Délai entre les pages (en secondes) - valeurs min/max
DELAY_MIN=5.0
DELAY_MAX=9.0

# Tentatives en cas d'échec
MAX_RETRY=2
