# ============================================================================
# CONFIGURATION ALTERNAX v1.1.0
# ============================================================================
# Copier ce fichier en .env et adapter à votre environnement

# ============================================================================
# BASE DE DONNÉES
# ============================================================================
# PostgreSQL (Neon, Supabase, Railway, etc.)
# Laisser vide en local → SQLite automatique (data/offers.db)
DATABASE_URL=postgresql://user:password@host/dbname

# ============================================================================
# API SERVER
# ============================================================================
# Adresse d'écoute du serveur
API_HOST=0.0.0.0

# Port du serveur
API_PORT=8000

# Mode reload au changement de fichier (dev seulement)
API_RELOAD=true

# Nombre de workers (prod: augmenter)
API_WORKERS=1

# ============================================================================
# FRONTEND
# ============================================================================
# URL du frontend déployé (pour restreindre le CORS)
# Laisser vide en local → CORS ouvert pour tous les domaines
FRONTEND_URL=https://votre-app.vercel.app

# ============================================================================
# CACHING
# ============================================================================
# Cache time-to-live pour les statistiques (secondes)
# Plus haut = moins de requêtes DB, mais données moins à jour
CACHE_TTL_STATS=300

# Cache time-to-live pour les sources (secondes)
CACHE_TTL_SOURCES=600

# ============================================================================
# LOGGING
# ============================================================================
# Niveaux: DEBUG, INFO (default), WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# SCRAPING
# ============================================================================
# Nombre de pages à scraper par session
SCRAPER_MAX_PAGES=5

# Délai minimum entre les pages (secondes)
SCRAPER_DELAY_MIN=5.0

# Délai maximum entre les pages (secondes)
SCRAPER_DELAY_MAX=9.0

# Nombre de tentatives en cas d'échec
SCRAPER_MAX_RETRY=2

# ============================================================================
# RATE LIMITING
# ============================================================================
# Activer le rate limiting (optionnel)
RATE_LIMIT_ENABLED=false

# Nombre maximum de requêtes par fenêtre
RATE_LIMIT_REQUESTS=100

# Durée de la fenêtre (secondes)
RATE_LIMIT_WINDOW=60

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Activer l'endpoint /api/health
FEATURE_HEALTH_CHECK=true

# Activer l'endpoint /api/metrics
FEATURE_METRICS=true

# Activer la documentation Swagger (/api/docs)
# À désactiver en production si vous voulez éviter d'exposer la doc
FEATURE_SWAGGER=true

# ============================================================================
# PAGINATION
# ============================================================================
# Nombre d'offres par défaut par page
PAGINATION_DEFAULT_PER_PAGE=20

# Nombre maximum d'offres par requête
PAGINATION_MAX_PER_PAGE=100
